    "db:migrate": "echo \"SQLite migrations are applied on startup\""
  },
  "dependencies": {
    "@caesar-geek/agent-runtime": "workspace:*",
    "@caesar-geek/shared": "workspace:*",
    "@caesar-geek/workspace": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@trpc/server": "^11.7.2",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.6.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
