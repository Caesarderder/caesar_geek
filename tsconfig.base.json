{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@caesar-geek/shared": ["packages/shared/src/index.ts"],
      "@caesar-geek/workspace": ["packages/workspace/src/index.ts"],
      "@caesar-geek/agent-runtime": ["packages/agent-runtime/src/index.ts"]
    }
  }
}
